# === Сервер ===
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# === База данных PostgreSQL ===
DATABASE_URL=postgresql://auth_user:auth_password@localhost:5432/auth_launcher?schema=public

# === JWT (для access/refresh токенов) ===
JWT_ACCESS_SECRET=сгенерируйте_случайную_строку_64_символа
JWT_REFRESH_SECRET=сгенерируйте_случайную_строку_64_символа
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === Argon2id (настройки хеширования паролей) ===
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=2
ARGON2_HASH_LENGTH=32

# === 2FA / TOTP ===
TOTP_ISSUER=AuthLauncher

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AUTH=5
RATE_LIMIT_MAX_GENERAL=100

# === CORS ===
CORS_ORIGINS=http://localhost:3000,https://ваш-домен.com

# === Администратор по умолчанию (создаётся скриптом seed) ===
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Admin123456!
ADMIN_EMAIL=admin@example.com